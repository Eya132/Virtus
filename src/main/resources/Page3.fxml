<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gestion_match.controller.DashboardController" spacing="20" alignment="CENTER" stylesheets="@styles/styles2.css">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Titre du tableau de bord -->
    <Label text="Tableau de bord des matchs" styleClass="dashboard-title">
        <font>
            <Font name="Segoe UI" size="26"/>
        </font>
    </Label>

    <!-- TableView pour afficher les matchs -->
    <TableView fx:id="matchTableView" prefWidth="900" prefHeight="450" styleClass="custom-table">
        <columns>
            <!-- Colonne pour la date du match -->
            <TableColumn text="Date" fx:id="dateColumn" prefWidth="150">
                <cellValueFactory>
                    <PropertyValueFactory property="dateMatch"/>
                </cellValueFactory>
            </TableColumn>

            <!-- Colonne pour l'heure du match -->
            <TableColumn text="Heure" fx:id="heureColumn" prefWidth="100">
                <cellValueFactory>
                    <PropertyValueFactory property="heure"/>
                </cellValueFactory>
            </TableColumn>

            <!-- Colonne pour la localisation du match -->
            <TableColumn text="Localisation" fx:id="localisationColumn" prefWidth="200">
                <cellValueFactory>
                    <PropertyValueFactory property="localisation"/>
                </cellValueFactory>
            </TableColumn>

            <!-- Colonne pour le type de sport -->
            <TableColumn text="Sport" fx:id="typeSportColumn" prefWidth="150">
                <cellValueFactory>
                    <PropertyValueFactory property="typeSport"/>
                </cellValueFactory>
            </TableColumn>

            <!-- Colonne pour le rôle de l'utilisateur (planificateur/participant) -->
            <TableColumn text="Rôle" fx:id="roleColumn" prefWidth="150">
                <cellValueFactory>
                    <PropertyValueFactory property="role"/>
                </cellValueFactory>
            </TableColumn>


            <!-- Colonne pour les actions (annuler/modifier) -->
            <TableColumn text="Actions" fx:id="actionColumn" prefWidth="250">
                <!-- La fabrique de cellules personnalisée sera définie dans le contrôleur -->
            </TableColumn>
        </columns>
    </TableView>

    <!-- Bouton pour rafraîchir la liste des matchs -->
    <Button text="Rafraîchir" onAction="#loadMatchsForUser" styleClass="refresh-button"/>
</VBox>