<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gestion_match.controller.ModifierMatchController" spacing="10" alignment="CENTER">
    <GridPane hgap="10" vgap="10">
        <!-- Titre -->
        <Label text="Modifier un match" style="-fx-font-size: 18; -fx-font-weight: bold;" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

        <!-- Champ : Date -->
        <Label text="Date :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <DatePicker fx:id="datePicker" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <!-- Champ : Heure -->
        <Label text="Heure :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="heureField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- Champ : Localisation -->
        <Label text="Localisation :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="localisationField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <!-- Champ : Terrain -->
        <Label text="Terrain :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="terrainField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <!-- Champ : Type de sport -->
        <Label text="Type de sport :" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="typeSportField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>



    </GridPane>

    <!-- Bouton : Enregistrer les modifications -->
    <Button text="Enregistrer" onAction="#enregistrerModifications" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
</VBox>