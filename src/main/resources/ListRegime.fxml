<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GestionRegime.controller.Regime.ListeRegimeController" stylesheets="/styles.css">
   <!-- Top Section: Title -->
   <top>
      <HBox alignment="CENTER" prefHeight="41.0" prefWidth="638.0">
         <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
         </padding>
         <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Liste des Régimes Alimentaires" />
      </HBox>
   </top>

   <!-- Center Section: TableView -->
   <center>
      <TableView fx:id="regimeTable">
         <columns>
            <TableColumn fx:id="idColumn" text="ID" />
            <TableColumn fx:id="objectifColumn" text="Objectif" />
            <TableColumn fx:id="caloriesColumn" text="Calories" />
            <TableColumn fx:id="proteinesColumn" text="Protéines" />
            <TableColumn fx:id="glucidesColumn" text="Glucides" />
            <TableColumn fx:id="lipidesColumn" text="Lipides" />
            <TableColumn fx:id="dateDebutColumn" text="Date Début" />
            <TableColumn fx:id="dateFinColumn" text="Date Fin" />
            <TableColumn fx:id="statusColumn" text="Statut" />
         </columns>
      </TableView>
   </center>

   <!-- Bottom Section: Buttons -->
   <bottom>
      <HBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
         <Button onAction="#handleModifierRegimeButton" text="Modifier" />
         <Button onAction="#handleSupprimerRegimeButton" text="Supprimer" />
      </HBox>
   </bottom>
</BorderPane>