<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GestionRegime.controller.Suivi.AjouterSuivi">
    <Label text="Ajouter un Suivi" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <GridPane hgap="10" vgap="10">
        <!-- ComboBox pour sélectionner un régime -->
        <Label text="Régime:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="regimeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Champs pour afficher les détails du régime -->
        <Label text="Objectif:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="objectifField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Calories journalières:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="caloriesField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Protéines:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="proteinesField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Glucides:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="glucidesField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Lipides:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="lipidesField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <!-- Champs pour ajouter un suivi -->
        <Label text="Poids (kg):" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="poidsField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="Tour de Taille (cm):" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="tourDeTailleField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <Label text="IMC:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <TextField fx:id="imcField" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
    </GridPane>
    <Button text="Ajouter" onAction="#handleAjouterSuivi" />
</VBox>